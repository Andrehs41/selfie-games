# Puerto del servidor
PORT=4000

# Conexión a MongoDB (local o Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/selfie-games

# Secreto para firmar los JWT (cámbialo por algo largo y aleatorio)
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# Origen permitido del frontend (CORS)
CLIENT_ORIGIN=http://localhost:5173

# Admin inicial (usado por `npm run seed:admin`)
ADMIN_NOMBRE=Administrador
ADMIN_EMAIL=admin@bymarianazapata.com
ADMIN_PASSWORD=cambia-esta-clave
